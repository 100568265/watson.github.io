yle=&#34;display:flex;&#34;&gt;&lt;span&gt;matrix_33&lt;span style=&#34;color:#1f2328&#34;&gt;.&lt;/span&gt;determinant&lt;span style=&#34;color:#1f2328&#34;&gt;();&lt;/span&gt;    &lt;span style=&#34;color:#57606a&#34;&gt;// 行列式&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#57606a&#34;&gt;// 特征值/特征向量&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#57606a&#34;&gt;// 实对称矩阵可以保证对角化成功&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;Eigen&lt;span style=&#34;color:#0550ae&#34;&gt;::&lt;/span&gt;SelfAdjointEigenSolver&lt;span style=&#34;color:#0550ae&#34;&gt;&amp;lt;&lt;/span&gt;Eigen&lt;span style=&#34;color:#0550ae&#34;&gt;::&lt;/span&gt;Matrix3d&lt;span style=&#34;color:#0550ae&#34;&gt;&amp;gt;&lt;/span&gt; eigen_solver &lt;span style=&#34;color:#1f2328&#34;&gt;(&lt;/span&gt;matrix_33&lt;span style=&#34;color:#1f2328&#34;&gt;.&lt;/span&gt;transpose&lt;span style=&#34;color:#1f2328&#34;&gt;()&lt;/span&gt;&lt;span style=&#34;color:#0550ae&#34;&gt;*&lt;/span&gt;matrix_33&lt;span style=&#34;color:#1f2328&#34;&gt;);&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;cout &lt;span style=&#34;color:#0550ae&#34;&gt;&amp;lt;&amp;lt;&lt;/span&gt; &lt;span style=&#34;color:#0a3069&#34;&gt;&amp;#34;Eigen values = &amp;#34;&lt;/span&gt; &lt;span style=&#34;color:#0550ae&#34;&gt;&amp;lt;&amp;lt;&lt;/span&gt; eigen_solver&lt;span style=&#34;color:#1f2328&#34;&gt;.&lt;/span&gt;eigenvalues&lt;span style=&#34;color:#1f2328&#34;&gt;()&lt;/span&gt; &lt;span style=&#34;color:#0550ae&#34;&gt;&amp;lt;&amp;lt;&lt;/span&gt; endl&lt;span style=&#34;color:#1f2328&#34;&gt;;&lt;/span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;